{
  "name": "Webcompooler",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "prettier": "^3.7.4",
    "turbo": "^2.10.1",
    "typescript": "5.9.2"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "backend": "bun --watch apps/backend/index.ts",
    "worker": "bun --watch apps/worker/index.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
